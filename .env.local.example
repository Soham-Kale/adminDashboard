# ── Admin Dashboard — Environment Variables ──────────────────────────────

# Long-lived bot JWT for server-to-server calls (never expose to the browser)
SERVICE_JWT_TOKEN=<paste-your-jwt-here>

# Flask API base URL (server-side only — never prefix with NEXT_PUBLIC_)
API_BASE_URL=https://api-dev.uinsports.com

# Set to "true" to skip real API and use local dummy data
NEXT_PUBLIC_USE_MOCK_DATA=false

# Public site URL — used for SEO metadata
NEXT_PUBLIC_SITE_URL=https://admin.uinsports.com
